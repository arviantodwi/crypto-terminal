# CoinDesk API key — required
# Obtain from https://developers.coindesk.com
COINDESK_API_KEY=your_api_key_here

# CoinDesk base URL — required
COINDESK_BASE_URL=https://data-api.coindesk.com

# PostgreSQL connection string — required
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://changeme:changeme@localhost:5432/changeme

# Port the service listens on — optional, defaults to 3002
PORT=3002

# Pino log level — optional, defaults to info
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Delay between CoinDesk API pages during seed (milliseconds). 0 = no delay.
SEED_PAGES_DELAY_MS=100
